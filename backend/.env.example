# Anthropic API (agent model: claude-sonnet-4-5)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (PostgreSQL + PostGIS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_ANON_KEY=your-anon-key-here
# Direct Postgres connection (asyncpg bulk ingestion + migrations)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# Ingestion / enrichment sources
RENTCAST_API_KEY=your-rentcast-key
RENTCAST_MONTHLY_LIMIT=50
MAPBOX_TOKEN=pk.your-mapbox-token
CENSUS_API_KEY=your-census-key          # optional
WALKSCORE_API_KEY=your-walkscore-key    # optional

# Ingestion scope overrides (comma-separated; defaults in backend/ingestion/config.py)
# SEEDED_ZIPS=75201,75204,75205,75225,75248
# COUNTIES_ACTIVE=dallas

# Environment
ENVIRONMENT=development
